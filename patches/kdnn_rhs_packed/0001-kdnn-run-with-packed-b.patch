@@ -111,0 +117,20 @@ std::weak_ptr<ImplBase<GemmInfo>> FindSolution(const GemmInfo &task, IntType nTh
+std::shared_ptr<ImplBase<GemmInfo>> FindPackedBSolution(const GemmInfo &task, IntType nThreads) noexcept(false)
+{
+    VERBOSE_PRINT;
+    std::shared_ptr<ImplGenerator<GemmInfo>> ret;
+    std::chrono::duration<float, std::milli> bestTime =
+        std::chrono::duration<float, std::milli>{std::numeric_limits<float>::max()};
+    for (auto&& implKind : g_packedBImplKinds) {
+        if (implKind->Supports(task)) {
+            auto currentEstimatedTime = implKind->EstimateTime(task, nThreads);
+            if (currentEstimatedTime < bestTime) {
+                bestTime = currentEstimatedTime;
+                ret = implKind;
+            }
+        }
+    }
+    if (ret == nullptr) {
+        throw Service::LogicError {"Packed-B solution for GEMM wasn't found"};
+    }
+    return ret->GetImpl(task, nThreads);
+}
