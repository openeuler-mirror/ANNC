+        kBlockExecResid * vl, static_cast<IntType>(offsetDst), static_cast<IntType>(offsetBia), attributes);
+    matmulCodegenKernels = {std::move(cgw0), std::move(cgw1), std::move(cgw2), std::move(cgw3),
+                              std::move(cgw4), std::move(cgw5), std::move(cgw6), std::move(cgw7),
+                              std::move(cgw8), std::move(cgw9), std::move(cgw10), std::move(cgw11),
+                              std::move(cgw12), std::move(cgw13), std::move(cgw14), std::move(cgw15),
+                              std::move(cgw16), std::move(cgw17)};
+}
+void MatMulImplGeneratorNoPack::DefaultImplNoPack::InitializeReorderCodeGens(
+    IntType m, IntType n, IntType k, IntType vlw, IntType mFull, IntType nFull)
+{
+    Service::Unused(m, n, mFull);
+    IntType vl = vlw;
+    IntType nFullThreadBlock = nFull;
+    IntType nResidThreadBlock = n % nFullThreadBlock;
+    IntType nBlockExecResid1 = nFullThreadBlock % vl;
+    IntType nBlockExecResid2 = nResidThreadBlock % vl;
+    IntType kBlockExecFull = K_BLOCK_SIZE;
+    IntType kBlockExecResid = k % kBlockExecFull;
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderFNFKA;
+    reorderFNFKA.Initialize(static_cast<SizeType>(vl), static_cast<SizeType>(kBlockExecFull), true);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderFNRKA;
+    reorderFNRKA.Initialize(static_cast<SizeType>(vl), static_cast<SizeType>(kBlockExecResid), true);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN1FKA;
+    reorderRN1FKA.Initialize(static_cast<SizeType>(nBlockExecResid1), static_cast<SizeType>(kBlockExecFull), true);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN1RKA;
+    reorderRN1RKA.Initialize(static_cast<SizeType>(nBlockExecResid1), static_cast<SizeType>(kBlockExecResid), true);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN2FKA;
+    reorderRN2FKA.Initialize(static_cast<SizeType>(nBlockExecResid2), static_cast<SizeType>(kBlockExecFull), true);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN2RKA;
+    reorderRN2RKA.Initialize(static_cast<SizeType>(nBlockExecResid2), static_cast<SizeType>(kBlockExecResid), true);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderFNFKNA;
+    reorderFNFKNA.Initialize(static_cast<SizeType>(vl), static_cast<SizeType>(kBlockExecFull), false);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderFNRKNA;
+    reorderFNRKNA.Initialize(static_cast<SizeType>(vl), static_cast<SizeType>(kBlockExecResid), false);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN1FKNA;
+    reorderRN1FKNA.Initialize(static_cast<SizeType>(nBlockExecResid1), static_cast<SizeType>(kBlockExecFull), false);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN1RKNA;
+    reorderRN1RKNA.Initialize(static_cast<SizeType>(nBlockExecResid1), static_cast<SizeType>(kBlockExecResid), false);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN2FKNA;
+    reorderRN2FKNA.Initialize(static_cast<SizeType>(nBlockExecResid2), static_cast<SizeType>(kBlockExecFull), false);
+    CodeGenWrapper<FastReorderKernelCodeGen<float, float>> reorderRN2RKNA;
+    reorderRN2RKNA.Initialize(static_cast<SizeType>(nBlockExecResid2), static_cast<SizeType>(kBlockExecResid), false);
+    reorderPackingCodegenKernels = {
+        std::move(reorderFNFKA), std::move(reorderFNRKA),
+        std::move(reorderRN1FKA), std::move(reorderRN1RKA),
+        std::move(reorderRN2FKA), std::move(reorderRN2RKA),
+        std::move(reorderFNFKNA), std::move(reorderFNRKNA),
+        std::move(reorderRN1FKNA), std::move(reorderRN1RKNA),
+        std::move(reorderRN2FKNA), std::move(reorderRN2RKNA),
+    };
+}
+void MatMulImplGeneratorNoPack::DefaultImplNoPack::InitializePackingCodeGens(
+    IntType m, IntType n, IntType k, IntType vlw, IntType mFull, IntType nFull)
+{
+    Service::Unused(m, n, k, vlw, nFull, mFull);
+    IntType nFullThreadBlock = nFull;
+    IntType nResidThreadBlock = n % nFullThreadBlock;
+    IntType nBlockExecFull = N_BLOCK_SIZE;
+    IntType nBlockExecResid1 = nFullThreadBlock % nBlockExecFull;
+    IntType nBlockExecResid2 = nResidThreadBlock % nBlockExecFull;
+    CodeGenWrapper<PackBRowDefaultSchemeCodegenF32> cgwPackBrowBNAlpha;
+    cgwPackBrowBNAlpha.Initialize(nBlockExecFull, true);
+    CodeGenWrapper<PackBRowDefaultSchemeCodegenF32> cgwPackBrowR1NAlpha;
+    cgwPackBrowR1NAlpha.Initialize(nBlockExecResid1, true);
+    CodeGenWrapper<PackBRowDefaultSchemeCodegenF32> cgwPackBrowR2NAlpha;
+    cgwPackBrowR2NAlpha.Initialize(nBlockExecResid2, true);
+    CodeGenWrapper<PackBRowDefaultSchemeCodegenF32> cgwPackBrowBNnoAlpha;
+    cgwPackBrowBNnoAlpha.Initialize(nBlockExecFull, false);
+    CodeGenWrapper<PackBRowDefaultSchemeCodegenF32> cgwPackBrowR1NnoAlpha;
+    cgwPackBrowR1NnoAlpha.Initialize(nBlockExecResid1, false);
+    CodeGenWrapper<PackBRowDefaultSchemeCodegenF32> cgwPackBrowR2NnoAlpha;
+    cgwPackBrowR2NnoAlpha.Initialize(nBlockExecResid2, false);
+    vectorPackBRowCodegenKernels = {
+        std::move(cgwPackBrowBNAlpha), std::move(cgwPackBrowR1NAlpha), std::move(cgwPackBrowR2NAlpha),
+        std::move(cgwPackBrowBNnoAlpha), std::move(cgwPackBrowR1NnoAlpha), std::move(cgwPackBrowR2NnoAlpha),
+    };
+}
+void MatMulImplGeneratorNoPack::DefaultImplNoPack::InitializeThreadsCountImpl()
+{
+    IntType threadNumber = NUM_80;
+    IntType size = GetRequiredMemSize();
+    if (size < 21216) {
+        threadNumber = NUM_1;
+    } else if (size < 58858) {
+        threadNumber = NUM_8;
+    } else if (size < 115296) {
+        threadNumber = NUM_24;
+    } else if (size < 355776) {
+        threadNumber = NUM_40;
+    }
+    nThreadsExec = std::min(threadNumber, implNThreads);
+}
