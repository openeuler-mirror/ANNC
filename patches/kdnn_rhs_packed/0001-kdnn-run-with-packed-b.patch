+struct MatMulImplGeneratorNoPack: MatmulTypeHelper<float, float, float, float>, ImplGenerator<GemmInfo> {
+    using CodeGen = MatMulKernelDefaultCodeGen<ARCH::NEON, float, float, float, float,
+        MatMulImplKinds::F32F32F32F32_NEON>;
+    struct DefaultImplNoPack : MatMulImplBase {
+        DefaultImplNoPack(const GemmInfo &task, IntType nThreads);
+        constexpr static std::uint32_t GetKernelMSize() noexcept;
+        static std::uint32_t GetKernelNSize() noexcept;
+    protected:
+        void InitializeCodeGens(IntType m, IntType n, IntType k, IntType vlw,
+            SizeType offsetSrc, SizeType offsetWei, SizeType offsetDst, SizeType offsetBia,
+            bool wereSrcWeiSwapped, IntType mFull, IntType nFull, const Attributes &attributes) override;
+        void InitializePackingCodeGens(IntType m, IntType n, IntType k,
+            IntType vlw, IntType mFull, IntType nFull) override;
+        void InitializeReorderCodeGens(IntType m, IntType n, IntType k,
+            IntType vlw, IntType mFull, IntType nFull) override;
+        void InitializeThreadsCountImpl() override;
+        IntType GetThreadBufSize(IntType m, IntType n, IntType k, IntType vlw,
+            MatrixKind mKind) const noexcept override;
+        void ReserveImplSpecificParams() override;
+        std::vector<std::pair<Shape, Shape>> SplitWork() override;
+        void RunSequential2D(IntType threadID, const void *src, const void *wei, void *dst, const void *bia,
+            std::unique_ptr<PackStrategy> &srcPackStrategy, std::unique_ptr<PackStrategy> &weiPackStrategy,
+            float alpha, float beta, const PostOpsDataPtrs &shiftedByBatchPOPtrs) const noexcept(false) override;
+        void UpdateExecParams() noexcept override;
+        constexpr static IntType M_BLOCK_SIZE = 1200;
+        constexpr static IntType K_BLOCK_SIZE = 640;
+        constexpr static IntType N_BLOCK_SIZE = 256;
+        std::array<CodeGenWrapper<CodeGen>, NUM_18> matmulCodegenKernels;
+        std::array<CodeGenWrapper<PackBRowDefaultSchemeCodegenF32>, NUM_6> vectorPackBRowCodegenKernels;
+        std::array<CodeGenWrapper<FastReorderKernelCodeGen<float, float>>,
+            NUM_12> reorderPackingCodegenKernels;
+    };
+    bool Supports(const GemmInfo &task) const noexcept override
+    {
+        VERBOSE_PRINT;
+        return task.srcInfo.GetType() == Element::TypeT::F32 &&
+            task.weiInfo.GetType() == Element::TypeT::F32 &&
+            task.dstInfo.GetType() == Element::TypeT::F32 &&
+            IsLayoutAlikeAB(task.srcInfo.GetLayout()) &&
+            IsLayoutAlikeAB(task.weiInfo.GetLayout()) &&
+            IsLayoutAlikeAB(task.dstInfo.GetLayout());
+    }
+    std::chrono::duration<float, std::milli> EstimateTime(const GemmInfo &task,
+                                                          IntType nThreads) const noexcept override
+    {
+        VERBOSE_PRINT;
+        float singleThreadPerformance = NUM_77;
+        if (std::getenv("KDNN_FORCE_NEON")) {
+#ifdef KDNNL_920F
+            singleThreadPerformance = 512;
+#else
+            singleThreadPerformance = 96;
+#endif
+        }
+        return CalculateMatmulTimeWithReorder<float, float, float, float>(
+            singleThreadPerformance, task, nThreads);
+    }
+    std::shared_ptr<ImplBase<GemmInfo>> GetImpl(const GemmInfo &task, IntType nThreads) const override
+    {
+        VERBOSE_PRINT;
+        return std::make_shared<DefaultImplNoPack>(task, nThreads);
+    }
+};
